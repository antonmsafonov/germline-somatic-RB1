risk.table= TRUE, tables.height = 0.20,
tables.theme = theme_cleantable(),
censor = TRUE,
break.time.by = 12,
fontsize = 3,
axes.offset = FALSE,
xlab = "Follow up time (mo)",
xlim = c(0,84))
summary(coxph(Surv(time1, time2, os.event) ~ ET.partner + RB1.LOH, data = cdk1))
cdk1 <- cdk1 %>% mutate(rb1_ascn = factor(rb1_ascn, levels = c("Heterozygous", "Other_LOH", "Het_loss")))
#OS - unadjusted by FGA, WGD
os.un <- coxph(Surv(time1, time2, os.event) ~ rb1_ascn + ET.partner, data = cdk1)
t.os.un <- broom::tidy(os.un, exponentiate = TRUE, conf.int = TRUE) %>% filter(term %in% c("rb1_ascnOther_LOH", "rb1_ascnHet_loss")) %>% select(term, estimate, p.value, conf.low, conf.high) %>% mutate(analysis = "OS_univariate")
#OS - adjusted by FGA, WGD
os.adj <- coxph(Surv(time1, time2, os.event) ~ rb1_ascn + ET.partner + wgd_bin + fga, data = cdk1)
t.os.adj <- broom::tidy(os.adj, exponentiate = TRUE, conf.int = TRUE) %>% filter(term %in% c("rb1_ascnOther_LOH", "rb1_ascnHet_loss")) %>% select(term, estimate, p.value, conf.low, conf.high) %>% mutate(analysis = "OS_multivariate")
#PFS - unadjusted by FGA, WGD
pfs.un <- coxph(Surv(PFS.time.months, PFS.event) ~ rb1_ascn + ET.partner, data = cdk1)
t.pfs.un <- broom::tidy(pfs.un, exponentiate = TRUE, conf.int = TRUE) %>% filter(term %in% c("rb1_ascnOther_LOH", "rb1_ascnHet_loss")) %>% select(term, estimate, p.value, conf.low, conf.high) %>% mutate(analysis = "PFS_univariate")
#PFS - adjusted by FGA, WGD
pfs.adj <- coxph(Surv(PFS.time.months, PFS.event) ~ rb1_ascn + ET.partner+ wgd_bin + fga, data = cdk1)
t.pfs.adj <- broom::tidy(pfs.adj, exponentiate = TRUE, conf.int = TRUE) %>% filter(term %in% c("rb1_ascnOther_LOH", "rb1_ascnHet_loss")) %>% select(term, estimate, p.value, conf.low, conf.high) %>% mutate(analysis = "PFS_multivariate")
ascn_outcomes_for_forest <- rbind(t.pfs.un, t.pfs.adj)
ascn_outcomes_for_forest <- rbind(ascn_outcomes_for_forest, t.os.un)
ascn_outcomes_for_forest <- rbind(ascn_outcomes_for_forest, t.os.adj)
ascn_outcomes_for_forest <- ascn_outcomes_for_forest %>% mutate(ascn = substr(term, 9, nchar(term))) %>% select(-term)
