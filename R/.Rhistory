tsg.g <- read.csv("../data/Supp_Fig3m_TSG_gain_pre_post_ANON.csv")
tsg.g <- tsg.g %>% select(-X)
tbl_counts <- tsg.g %>%
group_by(Group.coarse) %>%
summarise(
n_RB1     = sum(RB1 == 1, na.rm = TRUE),
n_non_RB1 = sum(non_RB1 == 1, na.rm = TRUE),
n_total   = n()
) %>%
ungroup()
