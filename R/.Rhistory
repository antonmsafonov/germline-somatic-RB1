select(Group.coarse, n_RB1, n_non_RB1, n_total) %>%
tidyr::pivot_longer(
cols = c(n_RB1, n_non_RB1),
names_to = "status",
values_to = "n") %>%
mutate(freq = n/n_total)
tsg <- tbl_counts %>% rename(Group = Group.coarse, res_type = status) %>% mutate(res_type = case_when(res_type == "n_RB1" ~ "RB1", TRUE ~ "Non_RB1"))
